---
import CompassMark from './CompassMark.astro';
import { t } from '../i18n/ui';
import { r } from '../i18n/routes';
import type { Lang } from '../lib/i18n-content';

const lang = (Astro.currentLocale ?? 'ro') as Lang;
const T = t(lang);
const R = r(lang);
const year = 2026;

// Proiectele autorului (instanța oficială e a lui Marian Matinca; fork-urile
// pot elimina secțiunea — e o listă simplă, nu logică).
// chatgpt: 'live' | 'soon' | null — la aprobările OpenAI, schimbă câmpul aici.
const CHATGPT_APP_URL = 'https://chatgpt.com/plugins/plugin_asdk_app_6a5a1e1c646881919ea3a47685739b06';
const PROJECTS: { href: string; label: string; chatgpt: 'live' | 'soon' | null }[] = [
  { href: 'https://mmatinca.eu', label: 'mmatinca.eu', chatgpt: null },
  { href: 'https://tv.madeinro.eu', label: 'tv.madeinro.eu', chatgpt: 'soon' },
  { href: 'https://avizo.ro', label: 'avizo.ro', chatgpt: null },
  { href: 'https://euaicomply.eu', label: 'euaicomply.eu', chatgpt: null },
  { href: 'https://travel-trends.mmatinca.eu', label: 'travel-trends.mmatinca.eu', chatgpt: 'soon' },
  { href: 'https://cand-reciclam.madeinro.eu', label: 'cand-reciclam.madeinro.eu', chatgpt: 'live' },
];

// Contactul pentru incidente cibernetice diferă pe țară (ro/en/hu = România).
const CYBER: Record<Lang, { href: string; text: string }> = {
  ro: { href: 'tel:1911', text: '1911' },
  en: { href: 'tel:1911', text: '1911' },
  hu: { href: 'tel:1911', text: '1911' },
  pl: { href: 'https://incydent.cert.pl', text: 'incydent.cert.pl' },
  cs: { href: 'https://www.csirt.cz', text: 'csirt.cz' },
  sk: { href: 'https://www.sk-cert.sk', text: 'sk-cert.sk' },
  it: { href: 'https://www.commissariatodips.it', text: 'commissariatodips.it' },
  fr: { href: 'https://www.cybermalveillance.gouv.fr', text: 'cybermalveillance.gouv.fr' },
  de: { href: 'https://www.bsi.bund.de', text: 'bsi.bund.de' },
};
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <a href={R.home} class="brand" aria-label={T('brand.aria')}>
        <CompassMark size={26} />
        <span>Digital Compass</span>
      </a>
      <p class="footer-tagline">{T('footer.tagline')}</p>
    </div>

    <nav aria-label={T('footer.nav.aria')} class="footer-nav">
      <a href={R.why}>{T('footer.why')}</a>
      <a href={R.sources}>{T('footer.sources')}</a>
      <a href={R.pwa}>{T('footer.pwa')}</a>
      <a href={R.howItWorks}>{T('footer.howItWorks')}</a>
    </nav>

    <nav aria-label={T('footer.projects')} class="footer-projects">
      <p class="footer-projects-title">{T('footer.projects')}</p>
      <ul>
        {
          PROJECTS.map((p) => (
            <li>
              <a href={p.href} rel="noopener">{p.label}</a>
              {p.chatgpt === 'live' && (
                <a class="footer-chatgpt live" href={CHATGPT_APP_URL} rel="noopener nofollow">
                  · {T('footer.chatgptNow')}
                </a>
              )}
              {p.chatgpt === 'soon' && <span class="footer-chatgpt">· {T('footer.chatgptSoon')}</span>}
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="footer-emergency">
      <p class="footer-emergency-title">{T('footer.emergency.title')}</p>
      <p>
        {T('footer.emergency.line')} <a href="tel:112">112</a> ·
        {T('footer.emergency.cyber')}
        <a href={CYBER[lang].href}>{CYBER[lang].text}</a>
      </p>
    </div>
  </div>
  <div class="container footer-legal">
    <p>© {year} Digital Compass · {T('footer.legal')}</p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--space-section);
    border-top: 1px solid var(--color-border);
    background: var(--color-surface-2);
    padding-block: var(--space-5) var(--space-4);
  }
  .footer-inner {
    display: grid;
    gap: var(--space-4);
    grid-template-columns: 1fr;
  }
  @media (min-width: 48rem) {
    .footer-inner {
      grid-template-columns: 1.5fr 0.9fr 1.1fr 1fr;
      align-items: start;
    }
  }
  .footer-chatgpt {
    font-size: var(--text-xs, 0.75rem);
    color: var(--color-text-muted);
    margin-left: 0.35rem;
    white-space: nowrap;
  }
  .footer-chatgpt.live {
    color: var(--color-accent);
    text-decoration: none;
  }
  .footer-chatgpt.live:hover {
    text-decoration: underline;
  }
  .footer-projects-title {
    font-weight: var(--weight-bold);
    color: var(--color-text);
    font-size: var(--text-sm);
    margin-bottom: 0.5rem;
  }
  .footer-projects ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .footer-projects a {
    color: var(--color-text);
    text-decoration: none;
    font-size: var(--text-md);
  }
  .footer-projects a:hover {
    color: var(--color-text);
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: var(--color-text);
    text-decoration: none;
    font-weight: var(--weight-bold);
    font-size: var(--text-lg);
  }
  .footer-tagline {
    margin-top: var(--space-2);
    max-width: 34ch;
    color: var(--color-text);
    font-size: var(--text-md);
  }
  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .footer-nav a {
    color: var(--color-text);
    text-decoration: none;
    font-weight: var(--weight-medium);
  }
  .footer-nav a:hover {
    color: var(--color-text);
  }
  .footer-emergency-title {
    font-weight: var(--weight-bold);
    color: var(--color-text);
  }
  .footer-emergency {
    font-size: var(--text-md);
    color: var(--color-text);
  }
  .footer-legal {
    margin-top: var(--space-4);
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-border);
  }
  .footer-legal p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    max-width: 70ch;
  }
</style>
