---
/* Listă de semne: „good" (bune, verde ✓) sau „bad" (de alarmă, roșu !). */
interface Props {
  items: string[];
  variant: 'good' | 'bad';
}
const { items, variant } = Astro.props;
---

<ul class:list={['flaglist', variant]}>
  {
    items.map((item) => (
      <li>
        <span class="mark" aria-hidden="true">
          {variant === 'good' ? (
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
              <path d="M5 12.5l4.5 4.5L19 7.5" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          ) : (
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
              <path d="M12 7v6" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" />
              <circle cx="12" cy="17" r="1.3" fill="currentColor" />
            </svg>
          )}
        </span>
        <span set:html={item} />
      </li>
    ))
  }
</ul>

<style>
  .flaglist {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .flaglist li {
    display: flex;
    gap: 0.7rem;
    align-items: flex-start;
  }
  .mark {
    flex: none;
    margin-top: 0.15rem;
  }
  .good .mark {
    color: var(--color-safe);
  }
  .bad .mark {
    color: var(--color-danger);
  }
  .flaglist :global(strong) {
    font-weight: var(--weight-bold);
  }
</style>
