---
// Iconițe SVG inline pentru categoriile de situații (stroke, moștenesc culoarea).
// SVG, nu emoji — headerele de categorie sunt UI, nu conținut editorial.
interface Props {
  name: 'cumparaturi-bani' | 'conturi-dispozitive' | 'mesaje-apeluri' | 'oameni-manipulare' | 'ai-asistenti';
  size?: number;
}
const { name, size = 22 } = Astro.props;
const common = {
  width: size,
  height: size,
  viewBox: '0 0 24 24',
  fill: 'none',
  stroke: 'currentColor',
  'stroke-width': '1.9',
  'stroke-linecap': 'round' as const,
  'stroke-linejoin': 'round' as const,
  'aria-hidden': 'true',
};
---

{name === 'cumparaturi-bani' && (
  <svg {...common}>
    <circle cx="9" cy="20" r="1.4" />
    <circle cx="18" cy="20" r="1.4" />
    <path d="M2.5 3.5h2.2l2.4 12h11.4l2-8.5H6" />
  </svg>
)}
{name === 'conturi-dispozitive' && (
  <svg {...common}>
    <rect x="7" y="2.5" width="10" height="19" rx="2.2" />
    <path d="M10.5 5h3" />
    <path d="M9.5 13.2l1.8 1.8 3.4-3.6" />
  </svg>
)}
{name === 'mesaje-apeluri' && (
  <svg {...common}>
    <path d="M21 11.2a7.6 7.6 0 0 1-8.1 7.5 8.6 8.6 0 0 1-3.2-.6L4 19.5l1.5-4.2a7.2 7.2 0 0 1-1.3-4.1A7.6 7.6 0 0 1 12.3 3.7 7.6 7.6 0 0 1 21 11.2z" />
    <path d="M8.8 11.2h.01M12.3 11.2h.01M15.8 11.2h.01" stroke-width="2.4" />
  </svg>
)}
{name === 'oameni-manipulare' && (
  <svg {...common}>
    <circle cx="9" cy="8" r="3.2" />
    <path d="M3.5 20c.6-3.4 2.8-5.2 5.5-5.2s4.9 1.8 5.5 5.2" />
    <path d="M16.5 4.6a3.2 3.2 0 0 1 0 6.8" />
    <path d="M18.4 14.9c1.5.8 2.5 2.2 2.9 4.3" />
  </svg>
)}
{name === 'ai-asistenti' && (
  <svg {...common}>
    <path d="M12 3.5l1.6 4.4 4.4 1.6-4.4 1.6L12 15.5l-1.6-4.4-4.4-1.6 4.4-1.6z" />
    <path d="M18.5 15.5l.8 2.2 2.2.8-2.2.8-.8 2.2-.8-2.2-2.2-.8 2.2-.8z" />
  </svg>
)}
