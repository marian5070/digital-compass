---
import CompassMark from './CompassMark.astro';

const links = [
  { href: '/', label: 'Acasă' },
  { href: '/incepe-aici', label: 'Începe aici' },
  { href: '/ghiduri', label: 'Ghiduri' },
  { href: '/de-ce-existam', label: 'De ce existăm' },
  { href: '/surse', label: 'Surse' },
];

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label="Digital Compass — acasă">
      <CompassMark size={30} />
      <span class="brand-name">Digital Compass</span>
    </a>
    <nav aria-label="Navigare principală">
      <ul class="nav-list">
        {
          links.map((link) => {
            const target = link.href.replace(/\/$/, '') || '/';
            const isCurrent = target === path;
            return (
              <li>
                <a href={link.href} aria-current={isCurrent ? 'page' : undefined}>
                  {link.label}
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    background: color-mix(in oklch, var(--color-surface) 88%, transparent);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--color-border);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    min-height: 4rem;
    flex-wrap: wrap;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--color-text);
    text-decoration: none;
    font-weight: var(--weight-bold);
    letter-spacing: -0.01em;
  }
  .brand-name {
    font-size: var(--text-lg);
  }
  .nav-list {
    display: flex;
    align-items: center;
    gap: clamp(0.75rem, 0.4rem + 1.5vw, 1.75rem);
    list-style: none;
    padding: 0;
  }
  .nav-list a {
    color: var(--color-text-muted);
    text-decoration: none;
    font-weight: var(--weight-medium);
    padding: 0.35rem 0.1rem;
  }
  .nav-list a:hover {
    color: var(--color-text);
  }
  .nav-list a[aria-current='page'] {
    color: var(--color-accent-strong);
    box-shadow: inset 0 -0.14em 0 var(--color-accent);
  }
</style>
