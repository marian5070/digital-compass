---
import CompassMark from './CompassMark.astro';
import { t } from '../i18n/ui';
import { r } from '../i18n/routes';
import type { Lang } from '../lib/i18n-content';

// Path-urile paginii în fiecare limbă (pentru comutator), primite din layout.
interface Props {
  alternates?: Partial<Record<Lang, string>>;
}
const lang = (Astro.currentLocale ?? 'ro') as Lang;
const T = t(lang);
const R = r(lang);
const { alternates } = Astro.props;
const LANG_LABEL: Record<Lang, string> = {
  ro: 'Română',
  en: 'English',
  hu: 'Magyar',
  pl: 'Polski',
  cs: 'Čeština',
  sk: 'Slovenčina',
  it: 'Italiano',
  fr: 'Français',
  de: 'Deutsch',
};
const langEntries = Object.entries(alternates ?? {}) as [Lang, string][];

const links = [
  { href: R.home, label: T('nav.home') },
  { href: R.start, label: T('nav.start') },
  { href: R.guidesIndex, label: T('nav.guides') },
  { href: R.why, label: T('nav.why') },
  { href: R.sources, label: T('nav.sources') },
];

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class="site-header">
  <div class="container header-inner">
    <a href={R.home} class="brand" aria-label={T('brand.aria')}>
      <CompassMark size={30} />
      <span class="brand-name">Digital Compass</span>
    </a>

    {
      langEntries.length > 1 && (
        <details class="lang-menu">
          <summary aria-label="Limba / Language">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.8" />
              <path d="M3.5 12h17M12 3.5c-2.5 2.5-2.5 14.5 0 17M12 3.5c2.5 2.5 2.5 14.5 0 17" stroke="currentColor" stroke-width="1.5" />
            </svg>
            {lang.toUpperCase()}
            <span class="caret" aria-hidden="true">▾</span>
          </summary>
          <ul class="lang-list">
            {langEntries.map(([l, p]) => (
              <li>
                <a
                  href={p}
                  lang={l}
                  hreflang={l}
                  aria-current={l === lang ? 'true' : undefined}
                >
                  {LANG_LABEL[l]}
                </a>
              </li>
            ))}
          </ul>
        </details>
      )
    }

    <nav aria-label={T('nav.aria')} class="site-nav">
      <ul class="nav-list">
        {
          links.map((link) => {
            const target = link.href.replace(/\/$/, '') || '/';
            const isCurrent = target === path;
            return (
              <li>
                <a href={link.href} aria-current={isCurrent ? 'page' : undefined}>
                  {link.label}
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    background: color-mix(in oklch, var(--color-surface) 88%, transparent);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--color-border);
  }
  /* Mobil: două rânduri controlate — brand + limbă sus, navigarea (scrollabilă)
     dedesubt, pe un singur rând, fără frângerea etichetelor. */
  .header-inner {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    column-gap: var(--space-3);
    padding-block: 0.6rem 0;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--color-text);
    text-decoration: none;
    font-weight: var(--weight-bold);
    letter-spacing: -0.01em;
    margin-right: auto;
  }
  .brand-name {
    font-size: var(--text-lg);
    white-space: nowrap;
  }
  .site-nav {
    flex: 1 0 100%;
    min-width: 0;
    /* fade la margine — indiciu că lista continuă */
    -webkit-mask-image: linear-gradient(to right, black calc(100% - 2rem), transparent);
    mask-image: linear-gradient(to right, black calc(100% - 2rem), transparent);
  }
  .nav-list {
    display: flex;
    align-items: center;
    gap: clamp(0.9rem, 0.4rem + 1.5vw, 1.75rem);
    list-style: none;
    padding: 0;
    margin: 0;
    flex-wrap: nowrap;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-right: 2rem; /* loc sub fade pentru ultimul item */
  }
  .nav-list::-webkit-scrollbar {
    display: none;
  }
  .nav-list a {
    color: var(--color-text-muted);
    text-decoration: none;
    font-weight: var(--weight-medium);
    padding: 0.6rem 0.1rem;
    display: inline-block;
    white-space: nowrap;
  }
  .nav-list a:hover {
    color: var(--color-text);
  }
  .nav-list a[aria-current='page'] {
    color: var(--color-accent-strong);
    box-shadow: inset 0 -0.14em 0 var(--color-accent);
  }

  /* Desktop: totul pe un singur rând, ca înainte. */
  @media (min-width: 48rem) {
    .header-inner {
      flex-wrap: nowrap;
      min-height: 4rem;
      padding-block: 0;
    }
    .brand {
      margin-right: 0;
    }
    .site-nav {
      flex: 0 1 auto;
      margin-left: auto;
      -webkit-mask-image: none;
      mask-image: none;
    }
    .nav-list {
      overflow-x: visible;
      padding-right: 0;
    }
    .nav-list a {
      padding: 0.35rem 0.1rem;
    }
    .lang-menu {
      order: 3;
    }
  }

  .lang-menu {
    position: relative;
    flex: none;
  }
  .lang-menu summary {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    list-style: none;
    cursor: pointer;
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.3rem 0.75rem;
  }
  .lang-menu summary::-webkit-details-marker {
    display: none;
  }
  .lang-menu summary:hover {
    color: var(--color-text);
  }
  .lang-menu .caret {
    font-size: 0.7em;
  }
  .lang-menu[open] summary {
    color: var(--color-text);
    border-color: var(--color-accent);
  }
  .lang-list {
    position: absolute;
    right: 0;
    top: calc(100% + 0.4rem);
    z-index: 30;
    min-width: 9rem;
    list-style: none;
    padding: 0.35rem;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-lift);
  }
  .lang-list a {
    display: block;
    padding: 0.45rem 0.7rem;
    border-radius: calc(var(--radius) - 4px);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-decoration: none;
    font-weight: var(--weight-medium);
  }
  .lang-list a:hover {
    background: var(--color-surface-2);
    color: var(--color-text);
  }
  .lang-list a[aria-current='true'] {
    color: var(--color-accent-strong);
    font-weight: var(--weight-bold);
  }
</style>
