---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PlaybookCard from '../components/PlaybookCard.astro';
import { entrySlug, type Lang } from '../lib/i18n-content';
import { t } from '../i18n/ui';
import { r, pageAlternates } from '../i18n/routes';

// Indexul ghidurilor de prevenție, comun ambelor limbi.
interface Props {
  lang: Lang;
  ghiduri: CollectionEntry<'ghiduri'>[];
}
const { lang, ghiduri } = Astro.props;
const T = t(lang);
const R = r(lang);

// Categoriile, în ordinea de afișare. Eticheta + o descriere scurtă, pe limbă.
const CATEGORIES = [
  {
    key: 'email-mesaje',
    label: { ro: 'Email & mesaje', en: 'Email & messages', hu: 'Email & üzenetek', pl: 'E-mail i wiadomości', cs: 'E-mail a zprávy', sk: 'E-mail a správy', it: 'Email e messaggi', fr: 'Email et messages', de: 'E-Mail & Nachrichten', },
    desc: {
      ro: 'Cum îți dai seama cine îți scrie și unde duce un link, fără să-l deschizi.',
      en: 'How to tell who is really writing to you and where a link leads, without opening it.',
      hu: 'Hogyan látod, ki ír neked valójában, és hová vezet egy link — anélkül, hogy megnyitnád.',
      pl: 'Jak poznać, kto naprawdę do Ciebie pisze i dokąd prowadzi link — bez otwierania go.',
      cs: 'Jak poznat, kdo ti opravdu píše a kam vede odkaz — bez jeho otevření.',
      sk: 'Ako zistiť, kto ti naozaj píše a kam vedie odkaz — bez jeho otvorenia.',
      it: 'Come capire chi ti sta scrivendo davvero e dove porta un link, senza aprirlo.',
      fr: 'Comment savoir qui vous écrit vraiment et où mène un lien, sans l’ouvrir.',
      de: 'Wie Sie erkennen, wer Ihnen wirklich schreibt und wohin ein Link führt — ohne ihn zu öffnen.',
    },
  },
  {
    key: 'conturi-parole',
    label: { ro: 'Conturi & parole', en: 'Accounts & passwords', hu: 'Fiókok & jelszavak', pl: 'Konta i hasła', cs: 'Účty a hesla', sk: 'Účty a heslá', it: 'Account e password', fr: 'Comptes et mots de passe', de: 'Konten & Passwörter', },
    desc: {
      ro: 'Cum îți protejezi conturile înainte să pățești ceva.',
      en: 'How to protect your accounts before anything happens.',
      hu: 'Hogyan védd meg a fiókjaidat, mielőtt bármi történne.',
      pl: 'Jak chronić swoje konta, zanim cokolwiek się stanie.',
      cs: 'Jak ochránit své účty, než se něco stane.',
      sk: 'Ako ochrániť svoje účty, skôr než sa niečo stane.',
      it: 'Come proteggere i tuoi account prima che succeda qualcosa.',
      fr: 'Comment protéger vos comptes avant qu’il n’arrive quoi que ce soit.',
      de: 'Wie Sie Ihre Konten schützen, bevor etwas passiert.',
    },
  },
  {
    key: 'dispozitive',
    label: { ro: 'Telefon & dispozitive', en: 'Phone & devices', hu: 'Telefon & eszközök', pl: 'Telefon i urządzenia', cs: 'Telefon a zařízení', sk: 'Telefón a zariadenia', it: 'Telefono e dispositivi', fr: 'Téléphone et appareils', de: 'Telefon & Geräte', },
    desc: {
      ro: 'Actualizări, Wi-Fi public și ce faci când ești pe drum.',
      en: 'Updates, public Wi-Fi and staying safe on the move.',
      hu: 'Frissítések, nyilvános Wi-Fi, és biztonság útközben.',
      pl: 'Aktualizacje, publiczne Wi-Fi i bezpieczeństwo w drodze.',
      cs: 'Aktualizace, veřejná Wi-Fi a bezpečí na cestách.',
      sk: 'Aktualizácie, verejná Wi-Fi a bezpečie na cestách.',
      it: 'Aggiornamenti, Wi-Fi pubblico e sicurezza in viaggio.',
      fr: 'Mises à jour, Wi-Fi public et sécurité en déplacement.',
      de: 'Updates, öffentliches WLAN und Sicherheit unterwegs.',
    },
  },
  {
    key: 'cumparaturi-plati',
    label: { ro: 'Cumpărături & plăți', en: 'Shopping & payments', hu: 'Vásárlás & fizetés', pl: 'Zakupy i płatności', cs: 'Nákupy a platby', sk: 'Nákupy a platby', it: 'Acquisti e pagamenti', fr: 'Achats et paiements', de: 'Einkaufen & Bezahlen', },
    desc: {
      ro: 'Cum cumperi și plătești online în siguranță.',
      en: 'How to shop and pay online safely.',
      hu: 'Hogyan vásárolj és fizess biztonságosan online.',
      pl: 'Jak bezpiecznie kupować i płacić w internecie.',
      cs: 'Jak bezpečně nakupovat a platit online.',
      sk: 'Ako bezpečne nakupovať a platiť online.',
      it: 'Come comprare e pagare online in sicurezza.',
      fr: 'Comment acheter et payer en ligne en toute sécurité.',
      de: 'Wie Sie sicher online einkaufen und bezahlen.',
    },
  },
  {
    key: 'la-birou',
    label: { ro: 'La birou', en: 'At work', hu: 'A munkahelyen', pl: 'W pracy', cs: 'V práci', sk: 'V práci', it: 'Al lavoro', fr: 'Au travail', de: 'Im Büro', },
    desc: {
      ro: 'Reguli simple de siguranță pentru muncă — bune și pentru cineva nou într-o echipă.',
      en: 'Simple safety rules for work — good for anyone new on a team, too.',
      hu: 'Egyszerű biztonsági szabályok a munkához — új csapattagoknak is.',
      pl: 'Proste zasady bezpieczeństwa w pracy — dobre też dla nowych w zespole.',
      cs: 'Jednoduchá bezpečnostní pravidla pro práci — dobrá i pro nováčky v týmu.',
      sk: 'Jednoduché bezpečnostné pravidlá pre prácu — dobré aj pre nováčikov v tíme.',
      it: 'Regole semplici di sicurezza per il lavoro — utili anche a chi è nuovo in un team.',
      fr: 'Des règles simples de sécurité au travail — utiles aussi pour les nouveaux dans une équipe.',
      de: 'Einfache Sicherheitsregeln für die Arbeit — auch gut für Neue im Team.',
    },
  },
] as const;

const groups = CATEGORIES.map((cat) => ({
  ...cat,
  items: ghiduri
    .filter((g) => g.data.category === cat.key)
    .sort((a, b) => a.data.order - b.data.order),
})).filter((cat) => cat.items.length > 0);
---

<BaseLayout
  title={T('guides.title')}
  description={T('guides.desc')}
  alternates={pageAlternates('guidesIndex')}
>
  <section class="section">
    <div class="container">
      <div class="head">
        <span class="eyebrow">{T('guides.eyebrow')}</span>
        <h1>{T('guides.h1')}</h1>
        <p class="lead">{T('guides.lead')}</p>
      </div>

      {
        groups.map((cat) => (
          <section class="cat" aria-labelledby={`cat-${cat.key}`}>
            <div class="cat-head">
              <h2 id={`cat-${cat.key}`}>{cat.label[lang]}</h2>
              <p>{cat.desc[lang]}</p>
            </div>
            <div class="cards">
              {cat.items.map((g) => (
                <PlaybookCard
                  href={R.guide(entrySlug(g.id))}
                  title={g.data.title}
                  situation={g.data.topic}
                  icon={g.data.icon}
                  severity="important"
                />
              ))}
            </div>
          </section>
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  .head {
    max-width: 52ch;
    margin-bottom: var(--space-6);
  }
  .head h1 {
    margin-top: var(--space-2);
  }
  .head .lead {
    margin-top: var(--space-3);
  }
  .cat {
    margin-bottom: var(--space-6);
  }
  .cat-head {
    max-width: 52ch;
    margin-bottom: var(--space-4);
  }
  .cat-head h2 {
    font-size: var(--text-xl);
  }
  .cat-head p {
    margin-top: var(--space-1);
    color: var(--color-text-muted);
  }
  .cards {
    display: grid;
    gap: var(--space-4);
    grid-template-columns: 1fr;
  }
  @media (min-width: 40rem) {
    .cards {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
