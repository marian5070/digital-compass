---
import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import StepList from '../components/StepList.astro';
import DontList from '../components/DontList.astro';
import ReportBox from '../components/ReportBox.astro';
import SourceList from '../components/SourceList.astro';
import { entryLang, entrySlug, getPlaybooks } from '../lib/i18n-content';
import { t, type UiKey } from '../i18n/ui';
import { r, contentAlternates } from '../i18n/routes';
import PlaybookCard from '../components/PlaybookCard.astro';

// Corpul unei pagini de playbook, comun ambelor limbi.
interface Props {
  entry: CollectionEntry<'playbooks'>;
}
const { entry } = Astro.props;
const { data } = entry;
const lang = entryLang(entry.id);
const slug = entrySlug(entry.id);
const T = t(lang);
const R = r(lang);
const { Content } = await render(entry);

// Situații înrudite: aceeași categorie de use case, maxim 3.
const related = (await getPlaybooks(lang))
  .filter((p) => p.data.category === data.category && entrySlug(p.id) !== slug)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);
const catLabel = T(('cat.' + data.category) as UiKey);

// Structured data HowTo — ajută Google să afișeze pașii ca rezultat bogat,
// exact felul în care publicul nostru caută („ce fac dacă...").
const stripTags = (s: string) => s.replace(/<[^>]+>/g, '');
const howTo = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: data.title,
  description: data.summary,
  inLanguage: lang,
  step: data.steps.map((step, i) => ({
    '@type': 'HowToStep',
    position: i + 1,
    text: stripTags(step),
  })),
};
---

<BaseLayout
  title={data.title}
  description={data.summary}
  alternates={contentAlternates('playbook', slug)}
>
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(howTo)}
    is:inline
  />
  <article class="playbook">
    <div class="container">
      <nav class="crumbs" aria-label="breadcrumb">
        <a href={R.home} class="back">{T('pb.back')}</a>
        <span class="crumb-sep" aria-hidden="true">·</span>
        <a href={`${R.home}#cat-${data.category}`} class="back crumb-cat">{catLabel}</a>
      </nav>

      <header class="pb-header">
        {
          data.severity === 'urgent' && (
            <span class="tag tag-urgent">{T('pb.urgent')}</span>
          )
        }
        <h1>{data.title}</h1>
      </header>

      <div class="pb-grid">
        <div class="pb-main">
          <!-- Întâi, respiră (din corpul markdown) -->
          <section class="breathe" aria-label={T('pb.breathe.aria')}>
            <div class="content">
              <Content />
            </div>
          </section>

          <!-- Primii pași -->
          <section class="block block-steps" aria-labelledby="pasi">
            <h2 id="pasi">{T('pb.steps')}</h2>
            <StepList steps={data.steps} />
          </section>

          <!-- Ce să NU faci -->
          {
            data.donts.length > 0 && (
              <section class="block block-donts" aria-labelledby="nu">
                <h2 id="nu">{T('pb.donts')}</h2>
                <DontList items={data.donts} />
              </section>
            )
          }

          <!-- Cum recunoști data viitoare -->
          {
            data.recognize.length > 0 && (
              <section class="block" aria-labelledby="recunosti">
                <h2 id="recunosti">{T('pb.recognize')}</h2>
                <ul class="recognize">
                  {data.recognize.map((r) => (
                    <li set:html={r} />
                  ))}
                </ul>
              </section>
            )
          }
        </div>

        <aside class="pb-aside">
          {
            data.report.length > 0 && (
              <section class="block block-report" aria-labelledby="raportezi">
                <h2 id="raportezi">{T('pb.report')}</h2>
                <ReportBox channels={data.report} />
              </section>
            )
          }

          <section class="block block-sources" aria-labelledby="surse">
            <h2 id="surse" class="h-small">{T('pb.sources')}</h2>
            <SourceList sources={data.sources} lastReviewed={data.lastReviewed} />
          </section>
        </aside>
      </div>

      <p class="disclaimer">{T('pb.disclaimer')}</p>

      {
        related.length > 0 && (
          <aside class="related" aria-labelledby="inrudite">
            <h2 id="inrudite" class="h-small">{T('pb.related.h2')}</h2>
            <div class="related-cards">
              {related.map((p) => (
                <PlaybookCard
                  href={R.playbook(entrySlug(p.id))}
                  title={p.data.title}
                  situation={p.data.situation}
                  icon={p.data.icon}
                  severity={p.data.severity}
                />
              ))}
            </div>
          </aside>
        )
      }
    </div>
  </article>
</BaseLayout>

<style>
  .playbook {
    padding-top: var(--space-5);
  }
  .back {
    display: inline-block;
    margin-bottom: var(--space-4);
    font-weight: var(--weight-medium);
    text-decoration: none;
    color: var(--color-text-muted);
  }
  .back:hover {
    color: var(--color-accent-strong);
  }
  .pb-header {
    margin-bottom: var(--space-5);
  }
  .pb-header h1 {
    font-size: var(--text-2xl);
    max-width: 24ch;
  }
  .tag {
    display: inline-block;
    margin-bottom: var(--space-3);
    padding: 0.3rem 0.8rem;
    border-radius: 999px;
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
  }
  .tag-urgent {
    background: var(--color-danger-soft);
    color: var(--color-danger-text);
  }
  .pb-grid {
    display: grid;
    gap: var(--space-5);
    grid-template-columns: 1fr;
  }
  @media (min-width: 60rem) {
    .pb-grid {
      grid-template-columns: minmax(0, 1.7fr) minmax(0, 1fr);
      align-items: start;
    }
    .pb-aside {
      position: sticky;
      top: 5rem;
    }
  }
  .breathe {
    padding: var(--space-4);
    background: var(--color-accent-soft);
    border-radius: var(--radius);
    border-left: 4px solid var(--color-accent);
    margin-bottom: var(--space-5);
  }
  .breathe :global(p:first-child) {
    font-weight: var(--weight-bold);
    font-size: var(--text-lg);
  }
  .block {
    margin-bottom: var(--space-5);
  }
  .block h2 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-3);
  }
  .block h2.h-small {
    font-size: var(--text-lg);
  }
  .block-donts h2 {
    color: var(--color-danger-text);
  }
  .recognize {
    padding-left: 1.2em;
  }
  .recognize li + li {
    margin-top: var(--space-2);
  }
  .recognize :global(strong) {
    font-weight: var(--weight-bold);
  }
  .block-sources {
    padding: var(--space-4);
    background: var(--color-surface-2);
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
  }
  .crumbs {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    flex-wrap: wrap;
  }
  .crumb-sep {
    color: var(--color-text-muted);
  }
  .related {
    margin-top: var(--space-5);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
  }
  .related-cards {
    display: grid;
    gap: var(--space-3);
    grid-template-columns: 1fr;
    margin-top: var(--space-3);
  }
  @media (min-width: 48rem) {
    .related-cards {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .disclaimer {
    margin-top: var(--space-4);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
    max-width: var(--container-prose);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }
</style>
