---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PlaybookCard from '../components/PlaybookCard.astro';
import CompassMark from '../components/CompassMark.astro';
import CategoryIcon from '../components/CategoryIcon.astro';
import { entrySlug, type Lang } from '../lib/i18n-content';
import { t, type UiKey } from '../i18n/ui';
import { r, pageAlternates } from '../i18n/routes';

// Corpul homepage-ului, comun tuturor limbilor; paginile per-limbă sunt wrappere subțiri.
// UX 2.0: triaj (criză / prevenție / firmă) + situațiile grupate pe categorii de use case
// + filtru client-side minimal (progressive enhancement — fără JS totul rămâne vizibil).
interface Props {
  lang: Lang;
  playbooks: CollectionEntry<'playbooks'>[];
}
const { lang, playbooks } = Astro.props;
const T = t(lang);
const R = r(lang);

// Ordinea categoriilor = frecvența de uz (cumpărături primele).
const CATEGORY_ORDER = [
  'cumparaturi-bani',
  'conturi-dispozitive',
  'mesaje-apeluri',
  'oameni-manipulare',
] as const;

const catLabel = (c: (typeof CATEGORY_ORDER)[number]) => T(`cat.${c}` as UiKey);

const grouped = CATEGORY_ORDER.map((cat) => ({
  cat,
  items: playbooks
    .filter((p) => p.data.category === cat)
    .sort((a, b) => a.data.order - b.data.order),
})).filter((g) => g.items.length > 0);

// Structured data WebSite — identitatea site-ului în knowledge graph,
// cu publisher consecvent cu restul proprietăților (mmatinca.eu).
const webSite = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Digital Compass',
  url: 'https://compass.madeinro.eu/',
  description: T('home.desc'),
  inLanguage: ['ro', 'en'],
  license: 'https://creativecommons.org/licenses/by/4.0/',
  publisher: {
    '@type': 'Person',
    name: 'Marian Matinca',
    url: 'https://mmatinca.eu',
    jobTitle: 'AI Adoption Lead',
    sameAs: ['https://mmatinca.eu', 'https://github.com/marian5070'],
  },
};
---

<BaseLayout
  title={T('home.title')}
  description={T('home.desc')}
  alternates={pageAlternates('home')}
>
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(webSite)}
    is:inline
  />
  <!-- Hero + triaj -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-text">
        <span class="eyebrow">{T('home.eyebrow')}</span>
        <h1>{T('home.h1')}</h1>
        <p class="lead">{T('home.lead')}</p>
      </div>
      <div class="hero-mark" aria-hidden="true">
        <CompassMark size={160} />
      </div>
    </div>
    <div class="container">
      <nav class="triage" aria-label={T('home.cta')}>
        <a href="#situatii" class="triage-card triage-crisis">
          <span class="triage-t">{T('home.path.crisis.t')}</span>
          <span class="triage-d">{T('home.path.crisis.d')}</span>
        </a>
        <a href={R.guidesIndex} class="triage-card">
          <span class="triage-t">{T('home.path.prevent.t')}</span>
          <span class="triage-d">{T('home.path.prevent.d')}</span>
        </a>
        <a href={R.org} class="triage-card">
          <span class="triage-t">{T('home.path.org.t')}</span>
          <span class="triage-d">{T('home.path.org.d')}</span>
        </a>
      </nav>
    </div>
  </section>

  <!-- Situații, grupate pe categorii + filtru -->
  <section id="situatii" class="section">
    <div class="container">
      <div class="section-head">
        <h2>{T('home.situations.h2')}</h2>
        <p class="lead">{T('home.situations.lead')}</p>
      </div>

      <div class="filter" hidden data-filter-wrap>
        <svg class="filter-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <circle cx="11" cy="11" r="7" />
          <path d="m20 20-3.8-3.8" />
        </svg>
        <input
          type="search"
          id="situation-filter"
          placeholder={T('home.search.placeholder')}
          aria-label={T('home.search.placeholder')}
          autocomplete="off"
        />
      </div>

      {
        grouped.map(({ cat, items }) => (
          <div class="cat-group" data-cat-group>
            <h3 class="cat-head" id={`cat-${cat}`}>
              <span class="cat-icon">
                <CategoryIcon name={cat} />
              </span>
              {catLabel(cat)}
            </h3>
            <div class="cards">
              {items.map((pb) => (
                <div
                  data-card
                  data-search={`${pb.data.title} ${pb.data.situation} ${pb.data.summary}`.toLowerCase()}
                >
                  <PlaybookCard
                    href={R.playbook(entrySlug(pb.id))}
                    title={pb.data.title}
                    situation={pb.data.situation}
                    icon={pb.data.icon}
                    severity={pb.data.severity}
                    badge={pb.data.audience !== 'individ' ? T('badge.org') : undefined}
                  />
                </div>
              ))}
            </div>
          </div>
        ))
      }

      <p class="filter-none" hidden data-filter-none>{T('home.search.none')}</p>

      <script is:inline>
        // Filtru minimal: ascunde cardurile care nu conțin textul căutat.
        // Progressive enhancement — inputul apare doar dacă JS rulează.
        (function () {
          var wrap = document.querySelector('[data-filter-wrap]');
          var input = document.getElementById('situation-filter');
          var none = document.querySelector('[data-filter-none]');
          if (!wrap || !input || !none) return;
          wrap.hidden = false;
          var cards = [].slice.call(document.querySelectorAll('[data-card]'));
          var groups = [].slice.call(document.querySelectorAll('[data-cat-group]'));
          input.addEventListener('input', function () {
            var q = input.value.trim().toLowerCase();
            var visible = 0;
            cards.forEach(function (c) {
              var hit = !q || c.getAttribute('data-search').indexOf(q) !== -1;
              c.hidden = !hit;
              if (hit) visible++;
            });
            groups.forEach(function (g) {
              g.hidden = !g.querySelector('[data-card]:not([hidden])');
            });
            none.hidden = visible > 0;
          });
        })();
      </script>
    </div>
  </section>

  <!-- Prevenție -->
  <section class="section prevent">
    <div class="container prevent-inner">
      <div>
        <span class="eyebrow">{T('home.prevent.eyebrow')}</span>
        <h2>{T('home.prevent.h2')}</h2>
        <p class="lead">{T('home.prevent.lead')}</p>
      </div>
      <a href={R.guidesIndex} class="btn-ghost">{T('home.prevent.cta')}</a>
    </div>
  </section>

  <!-- De ce -->
  <section class="section why">
    <div class="container why-inner">
      <div class="prose">
        <span class="eyebrow">{T('home.why.eyebrow')}</span>
        <h2>{T('home.why.h2')}</h2>
        <p class="content">{T('home.why.p')}</p>
        <a href={R.why} class="link-arrow">{T('home.why.cta')}</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-block: var(--space-4) var(--space-4);
    background:
      radial-gradient(
        60% 80% at 85% 10%,
        var(--color-accent-soft),
        transparent 70%
      );
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    align-items: center;
  }
  @media (min-width: 56rem) {
    .hero-inner {
      grid-template-columns: 1.5fr 1fr;
      gap: var(--space-6);
    }
  }
  .hero-text h1 {
    margin-top: var(--space-2);
    max-width: 18ch;
  }
  .hero-text .lead {
    margin-top: var(--space-3);
    max-width: 52ch;
  }
  .hero-mark {
    display: none;
    color: var(--color-text-muted);
    justify-self: center;
  }
  @media (min-width: 56rem) {
    .hero-mark {
      display: block;
    }
  }

  /* Triaj — cele 3 căi de intrare */
  .triage {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3);
    margin-top: var(--space-3);
  }
  @media (min-width: 40rem) {
    .triage {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .triage-card {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: var(--space-3) var(--space-4);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-soft);
    text-decoration: none;
    color: var(--color-text);
    transition:
      transform var(--duration-normal) var(--ease-out-expo),
      box-shadow var(--duration-normal) var(--ease-out-expo),
      border-color var(--duration-normal) var(--ease-out-expo);
  }
  .triage-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lift);
    border-color: var(--color-accent);
  }
  .triage-crisis {
    border-color: var(--color-accent);
    background: var(--color-accent-soft);
  }
  .triage-t {
    font-weight: var(--weight-bold);
    font-size: var(--text-md);
    letter-spacing: -0.01em;
  }
  .triage-d {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .section-head {
    max-width: 46ch;
    margin-bottom: var(--space-4);
  }
  .section-head .lead {
    margin-top: var(--space-2);
  }

  /* Filtru */
  .filter {
    position: relative;
    max-width: 34rem;
    margin-bottom: var(--space-4);
  }
  .filter-icon {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-text-muted);
    pointer-events: none;
  }
  .filter input {
    width: 100%;
    padding: 1rem 1.1rem 1rem 2.9rem;
    font: inherit;
    font-size: var(--text-md);
    color: var(--color-text);
    background: var(--color-surface);
    border: 2px solid var(--color-accent);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-soft);
  }
  .filter input::placeholder {
    color: var(--color-text-muted);
  }
  .filter input:focus-visible {
    outline: 3px solid var(--color-accent);
    outline-offset: 2px;
  }
  .filter-none {
    color: var(--color-text-muted);
    padding-block: var(--space-3);
  }

  /* Grupuri de categorie */
  .cat-group {
    margin-bottom: var(--space-5);
  }
  .cat-head {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: var(--text-lg);
    letter-spacing: -0.01em;
    margin-bottom: var(--space-3);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--color-border);
  }
  .cat-icon {
    display: grid;
    place-items: center;
    width: 2.1rem;
    height: 2.1rem;
    border-radius: var(--radius);
    background: var(--color-accent-soft);
    color: var(--color-accent-strong);
  }
  .cards {
    display: grid;
    gap: var(--space-4);
    grid-template-columns: 1fr;
  }
  @media (min-width: 40rem) {
    .cards {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  .cards > div[hidden] {
    display: none;
  }

  .why {
    background: var(--color-surface-2);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }
  .why h2 {
    margin-top: var(--space-2);
    max-width: 20ch;
  }
  .why .content {
    margin-top: var(--space-3);
  }
  .link-arrow {
    display: inline-block;
    margin-top: var(--space-4);
    font-weight: var(--weight-bold);
    text-decoration: none;
  }
  .link-arrow:hover {
    text-decoration: underline;
  }
  .prevent-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
  }
  .prevent-inner > div {
    max-width: 46ch;
  }
  .prevent h2 {
    margin-top: var(--space-2);
  }
  .prevent .lead {
    margin-top: var(--space-2);
  }
  .btn-ghost {
    flex: none;
    padding: 0.8rem 1.4rem;
    border: 2px solid var(--color-accent);
    border-radius: var(--radius);
    color: var(--color-accent-strong);
    font-weight: var(--weight-bold);
    text-decoration: none;
    transition:
      background var(--duration-fast) var(--ease-out-expo),
      color var(--duration-fast) var(--ease-out-expo);
  }
  .btn-ghost:hover {
    background: var(--color-accent);
    color: var(--color-on-accent);
  }
</style>
