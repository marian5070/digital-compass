---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Traseu curat, în ordinea recomandată — oglinda EN a paginii /incepe-aici.
const path = [
  {
    label: 'Email & messages',
    desc: 'Almost every scam starts here. Learn to see who is really writing to you and where a link leads.',
    links: [
      { href: '/en/guides/cine-iti-scrie', title: 'Who is really writing to you?' },
      {
        href: '/en/guides/verifica-link-fara-sa-l-deschizi',
        title: 'How to check a link without opening it',
      },
    ],
  },
  {
    label: 'Accounts & passwords',
    desc: 'The most important protection step: a second step at sign-in.',
    links: [
      {
        href: '/en/guides/2fa-authenticator-passkey',
        title: 'How to protect your accounts',
      },
    ],
  },
  {
    label: 'Recognise the scams',
    desc: 'A few frequent situations — so you know them before they hit you.',
    links: [
      { href: '/en/playbook/link-sms-fals', title: 'Fake link or SMS' },
      { href: '/en/playbook/cont-spart', title: 'Hacked or locked account' },
      { href: '/en/playbook/real-sau-ai', title: 'Real, or made with AI?' },
      {
        href: '/en/playbook/oferta-investitii-crypto',
        title: 'Fraudulent investment or crypto offers',
      },
    ],
  },
  {
    label: 'At work (if you are employed)',
    desc: 'Simple rules for everyday work.',
    links: [
      {
        href: '/en/guides/email-de-la-sef-bec',
        title: 'An email from "the boss" demanding an urgent payment',
      },
      { href: '/en/guides/raporteaza-la-it', title: 'Report anything suspicious to IT' },
      {
        href: '/en/guides/datele-companiei-si-clientilor',
        title: 'Company and customer data',
      },
    ],
  },
];
---

<BaseLayout
  title="Start here"
  description="A simple path, in order, to learn the basics of digital safety — good for anyone new on a team, too. No jargon, no certificates."
  alternates={{ ro: '/incepe-aici', en: '/en/start-here', hu: '/hu/kezdd-itt' }}
>
  <section class="section">
    <div class="container">
      <div class="head">
        <span class="eyebrow">Recommended path</span>
        <h1>Start here</h1>
        <p class="lead">
          If you are new to the topic — or you just joined a team — go through
          the steps below, in order. In about 20 minutes you will have the
          basics that protect you from most traps. No jargon, no tests.
        </p>
      </div>

      <ol class="path">
        {
          path.map((step, i) => (
            <li class="step">
              <div class="step-num" aria-hidden="true">{i + 1}</div>
              <div class="step-body">
                <h2>{step.label}</h2>
                <p class="step-desc">{step.desc}</p>
                <ul class="step-links">
                  {step.links.map((l) => (
                    <li>
                      <a href={l.href}>{l.title} →</a>
                    </li>
                  ))}
                </ul>
              </div>
            </li>
          ))
        }
      </ol>

      <aside class="org">
        <h2>For organisations</h2>
        <p>
          Everything here is free to use (licensed
          <a href="/en/sources">CC BY</a>) as awareness and onboarding material
          in any organisation — you can send a new colleague straight to the
          path above.
        </p>
        <p>
          It can also support requirements like <strong>ISO 27001 (A.6.3 —
          awareness, education and training)</strong>. One thing stays clear, on
          principle: <strong>we do not issue certificates and we do not keep
          records</strong>. If an organisation needs proof of completion, it
          manages that itself, with its own tools. We only provide the
          knowledge.
        </p>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .head {
    max-width: 54ch;
    margin-bottom: var(--space-6);
  }
  .head h1 {
    margin-top: var(--space-2);
  }
  .head .lead {
    margin-top: var(--space-3);
  }
  .path {
    list-style: none;
    padding: 0;
    max-width: var(--container-prose);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .step {
    display: flex;
    gap: var(--space-3);
    padding: var(--space-4);
    background: var(--color-surface-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
  }
  .step-num {
    flex: none;
    display: grid;
    place-items: center;
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 50%;
    background: var(--color-accent);
    color: var(--color-on-accent);
    font-weight: var(--weight-bold);
  }
  .step-body h2 {
    font-size: var(--text-lg);
  }
  .step-desc {
    margin-top: 0.25rem;
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }
  .step-links {
    list-style: none;
    padding: 0;
    margin-top: var(--space-3);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .step-links a {
    font-weight: var(--weight-medium);
    text-decoration: none;
  }
  .step-links a:hover {
    text-decoration: underline;
  }
  .org {
    max-width: var(--container-prose);
    margin-top: var(--space-6);
    padding: var(--space-4);
    border-left: 4px solid var(--color-accent);
    background: var(--color-accent-soft);
    border-radius: var(--radius);
  }
  .org h2 {
    font-size: var(--text-lg);
  }
  .org p {
    margin-top: var(--space-2);
    font-size: var(--text-sm);
  }
</style>
