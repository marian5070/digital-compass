---
import { pageAlternates, r } from '../../i18n/routes';
import { t } from '../../i18n/ui';
import BaseLayout from '../../layouts/BaseLayout.astro';

// Czysta ścieżka, w zalecanej kolejności — polskie lustro strony /incepe-aici.
const path = [
  {
    label: 'E-mail i wiadomości',
    desc: 'Prawie każde oszustwo zaczyna się tutaj. Naucz się sprawdzać, kto naprawdę do ciebie pisze i dokąd prowadzi link.',
    links: [
      { href: '/pl/poradniki/cine-iti-scrie', title: 'Kto naprawdę do ciebie pisze?' },
      {
        href: '/pl/poradniki/verifica-link-fara-sa-l-deschizi',
        title: 'Jak sprawdzić link, nie otwierając go',
      },
    ],
  },
  {
    label: 'Konta i hasła',
    desc: 'Najważniejszy krok ochrony: drugi krok przy logowaniu.',
    links: [
      {
        href: '/pl/poradniki/2fa-authenticator-passkey',
        title: 'Jak chronić swoje konta',
      },
    ],
  },
  {
    label: 'Rozpoznaj oszustwa',
    desc: 'Kilka częstych sytuacji — poznaj je, zanim cię zaskoczą.',
    links: [
      { href: '/pl/playbook/link-sms-fals', title: 'Fałszywy link lub SMS' },
      { href: '/pl/playbook/cont-spart', title: 'Zhakowane lub zablokowane konto' },
      { href: '/pl/playbook/real-sau-ai', title: 'Prawdziwe czy zrobione przez AI?' },
      {
        href: '/pl/playbook/oferta-investitii-crypto',
        title: 'Oszukańcze oferty inwestycyjne i krypto',
      },
    ],
  },
  {
    label: 'W pracy (jeśli pracujesz)',
    desc: 'Proste zasady na co dzień w pracy.',
    links: [
      {
        href: '/pl/poradniki/email-de-la-sef-bec',
        title: 'E-mail od „szefa” z żądaniem pilnej płatności',
      },
      { href: '/pl/poradniki/raporteaza-la-it', title: 'Zgłaszaj do IT wszystko, co podejrzane' },
      {
        href: '/pl/poradniki/datele-companiei-si-clientilor',
        title: 'Dane firmy i klientów',
      },
    ],
  },
];

const T = t('pl');
const R = r('pl');
---

<BaseLayout
  title="Zacznij tutaj"
  description="Prosta ścieżka, krok po kroku, do podstaw cyfrowego bezpieczeństwa — przyda się też każdej nowej osobie w zespole. Bez żargonu, bez certyfikatów."
  alternates={pageAlternates('start')}
>
  <section class="section">
    <div class="container">
      <div class="head">
        <span class="eyebrow">Zalecana ścieżka</span>
        <h1>Zacznij tutaj</h1>
        <p class="lead">
          Jeśli temat jest dla ciebie nowy — albo właśnie dołączasz do zespołu
          — przejdź przez poniższe kroki po kolei. W około 20 minut zdobędziesz
          podstawy, które chronią przed większością pułapek. Bez żargonu, bez
          testów.
        </p>

        <nav class="aud-switch" aria-label="audience">
          <span class="aud-chip active" aria-current="page">{T('start.you')}</span>
          <a href={R.org} class="aud-chip">{T('start.org')}</a>
        </nav>
      </div>

      <ol class="path">
        {
          path.map((step, i) => (
            <li class="step">
              <div class="step-num" aria-hidden="true">{i + 1}</div>
              <div class="step-body">
                <h2>{step.label}</h2>
                <p class="step-desc">{step.desc}</p>
                <ul class="step-links">
                  {step.links.map((l) => (
                    <li>
                      <a href={l.href}>{l.title} →</a>
                    </li>
                  ))}
                </ul>
              </div>
            </li>
          ))
        }
      </ol>

      <aside class="org">
        <h2>Dla organizacji</h2>
        <p>
          Wszystko tutaj można bezpłatnie wykorzystywać (licencja
          <a href="/pl/zrodla">CC BY</a>) jako materiał uświadamiający i
          wdrożeniowy w każdej organizacji — nową osobę w zespole możesz od
          razu odesłać do powyższej ścieżki.
        </p>
        <p>
          Może też wspierać wymagania takie jak <strong>ISO 27001 (A.6.3 —
          świadomość, kształcenie i szkolenia)</strong>. Jedno pozostaje jasne,
          z zasady: <strong>nie wydajemy certyfikatów i nie prowadzimy
          ewidencji</strong>. Jeśli organizacja potrzebuje potwierdzenia
          ukończenia, zarządza tym sama, własnymi narzędziami. My dostarczamy
          tylko wiedzę.
        </p>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .head {
    max-width: 54ch;
    margin-bottom: var(--space-6);
  }
  .head h1 {
    margin-top: var(--space-2);
  }
  .head .lead {
    margin-top: var(--space-3);
  }
  .path {
    list-style: none;
    padding: 0;
    max-width: var(--container-prose);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .step {
    display: flex;
    gap: var(--space-3);
    padding: var(--space-4);
    background: var(--color-surface-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
  }
  .step-num {
    flex: none;
    display: grid;
    place-items: center;
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 50%;
    background: var(--color-accent);
    color: var(--color-on-accent);
    font-weight: var(--weight-bold);
  }
  .step-body h2 {
    font-size: var(--text-lg);
  }
  .step-desc {
    margin-top: 0.25rem;
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }
  .step-links {
    list-style: none;
    padding: 0;
    margin-top: var(--space-3);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .step-links a {
    font-weight: var(--weight-medium);
    text-decoration: none;
  }
  .step-links a:hover {
    text-decoration: underline;
  }
  .org {
    max-width: var(--container-prose);
    margin-top: var(--space-6);
    padding: var(--space-4);
    border-left: 4px solid var(--color-accent);
    background: var(--color-accent-soft);
    border-radius: var(--radius);
  }
  .org h2 {
    font-size: var(--text-lg);
  }
  .org p {
    margin-top: var(--space-2);
    font-size: var(--text-sm);
  }

  .aud-switch {
    display: inline-flex;
    gap: 0.5rem;
    margin-top: var(--space-4);
  }
  .aud-chip {
    padding: 0.45rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text-muted);
    text-decoration: none;
    background: var(--color-surface);
  }
  a.aud-chip:hover {
    border-color: var(--color-accent);
    color: var(--color-accent-strong);
  }
  .aud-chip.active {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: var(--color-on-accent);
  }
</style>
