---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PlaybookCard from '../components/PlaybookCard.astro';
import CompassMark from '../components/CompassMark.astro';

const playbooks = (await getCollection('playbooks')).sort(
  (a, b) => a.data.order - b.data.order
);

const description =
  'Ghid public, practic, în română, pentru momentele de criză digitală: link fals, cont spart, țeapă online, apel de înșelăciune. Pași clari, surse verificate. Nu diplome — claritate.';

// Structured data WebSite — identitatea site-ului în knowledge graph,
// cu publisher consecvent cu restul proprietăților (mmatinca.eu).
const webSite = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Digital Compass',
  url: 'https://compass.madeinro.eu/',
  description,
  inLanguage: 'ro',
  license: 'https://creativecommons.org/licenses/by/4.0/',
  publisher: {
    '@type': 'Person',
    name: 'Marian Matinca',
    url: 'https://mmatinca.eu',
    jobTitle: 'AI Adoption Lead',
    sameAs: ['https://mmatinca.eu', 'https://github.com/marian5070'],
  },
};
---

<BaseLayout title="Digital Compass" description={description}>
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(webSite)}
    is:inline
  />
  <!-- Hero -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-text">
        <span class="eyebrow">Ghid public · în română</span>
        <h1>Ți s-a întâmplat ceva online? Respiră. Îți spunem exact ce ai de făcut.</h1>
        <p class="lead">
          Fără jargon, fără diplome, fără să te sperie. Doar pași clari pentru
          momentele în care lumea digitală te prinde pe picior greșit — cu surse
          pe care le poți verifica.
        </p>
        <a href="#situatii" class="btn-primary">Alege situația ta ↓</a>
        <a href="/incepe-aici" class="hero-secondary">
          Ești nou aici sau ești o echipă? Începe aici →
        </a>
      </div>
      <div class="hero-mark" aria-hidden="true">
        <CompassMark size={220} />
      </div>
    </div>
  </section>

  <!-- Situații -->
  <section id="situatii" class="section">
    <div class="container">
      <div class="section-head">
        <h2>Care e situația ta acum?</h2>
        <p class="lead">Alege ce ți se întâmplă. Fiecare ghid începe cu primii pași, în ordine.</p>
      </div>
      <div class="cards">
        {
          playbooks.map((pb) => (
            <PlaybookCard
              href={`/playbook/${pb.id}`}
              title={pb.data.title}
              situation={pb.data.situation}
              icon={pb.data.icon}
              severity={pb.data.severity}
            />
          ))
        }
      </div>
    </div>
  </section>

  <!-- Prevenție -->
  <section class="section prevent">
    <div class="container prevent-inner">
      <div>
        <span class="eyebrow">Înainte să pățești</span>
        <h2>Vrei să eviți de la început?</h2>
        <p class="lead">
          Ghiduri proactive: la ce te uiți înainte să plătești, semnele de
          alarmă și regulile simple care te feresc.
        </p>
      </div>
      <a href="/ghiduri" class="btn-ghost">Vezi ghidurile →</a>
    </div>
  </section>

  <!-- De ce -->
  <section class="section why">
    <div class="container why-inner">
      <div class="prose">
        <span class="eyebrow">De ce existăm</span>
        <h2>Nu oferim diplome. Oferim claritate.</h2>
        <p class="content">
          Se vorbește mult despre digitalizare, securitate și „competențe
          digitale”, dar prea rar cineva îi explică omului obișnuit, pe limba
          lui, ce să facă atunci când chiar are o problemă. Noi asta acoperim:
          golul dintre discurs și un drum practic, public și accesibil.
        </p>
        <a href="/de-ce-existam" class="link-arrow">Vezi ce oferim și ce nu oferim →</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-block: var(--space-6) var(--space-5);
    background:
      radial-gradient(
        60% 80% at 85% 10%,
        var(--color-accent-soft),
        transparent 70%
      );
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    align-items: center;
  }
  @media (min-width: 56rem) {
    .hero-inner {
      grid-template-columns: 1.5fr 1fr;
      gap: var(--space-6);
    }
  }
  .hero-text h1 {
    margin-top: var(--space-2);
    max-width: 18ch;
  }
  .hero-text .lead {
    margin-top: var(--space-3);
    max-width: 52ch;
  }
  .hero-mark {
    display: none;
    color: var(--color-text-muted);
    justify-self: center;
  }
  @media (min-width: 56rem) {
    .hero-mark {
      display: block;
    }
  }
  .btn-primary {
    display: inline-block;
    margin-top: var(--space-4);
    padding: 0.85rem 1.5rem;
    background: var(--color-accent);
    color: var(--color-on-accent);
    border-radius: var(--radius);
    font-weight: var(--weight-bold);
    text-decoration: none;
    box-shadow: var(--shadow-soft);
    transition:
      transform var(--duration-fast) var(--ease-out-expo),
      background var(--duration-fast) var(--ease-out-expo);
  }
  .btn-primary:hover {
    background: var(--color-accent-strong);
    color: var(--color-on-accent);
    transform: translateY(-2px);
  }
  .hero-secondary {
    display: inline-block;
    margin-top: var(--space-3);
    margin-left: var(--space-3);
    font-weight: var(--weight-medium);
    color: var(--color-text-muted);
    text-decoration: none;
  }
  .hero-secondary:hover {
    color: var(--color-accent-strong);
    text-decoration: underline;
  }
  .section-head {
    max-width: 46ch;
    margin-bottom: var(--space-5);
  }
  .section-head .lead {
    margin-top: var(--space-2);
  }
  .cards {
    display: grid;
    gap: var(--space-4);
    grid-template-columns: 1fr;
  }
  @media (min-width: 40rem) {
    .cards {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  .why {
    background: var(--color-surface-2);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }
  .why h2 {
    margin-top: var(--space-2);
    max-width: 20ch;
  }
  .why .content {
    margin-top: var(--space-3);
  }
  .link-arrow {
    display: inline-block;
    margin-top: var(--space-4);
    font-weight: var(--weight-bold);
    text-decoration: none;
  }
  .link-arrow:hover {
    text-decoration: underline;
  }
  .prevent-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
  }
  .prevent-inner > div {
    max-width: 46ch;
  }
  .prevent h2 {
    margin-top: var(--space-2);
  }
  .prevent .lead {
    margin-top: var(--space-2);
  }
  .btn-ghost {
    flex: none;
    padding: 0.8rem 1.4rem;
    border: 2px solid var(--color-accent);
    border-radius: var(--radius);
    color: var(--color-accent-strong);
    font-weight: var(--weight-bold);
    text-decoration: none;
    transition:
      background var(--duration-fast) var(--ease-out-expo),
      color var(--duration-fast) var(--ease-out-expo);
  }
  .btn-ghost:hover {
    background: var(--color-accent);
    color: var(--color-on-accent);
  }
</style>
