---
import { pageAlternates } from '../i18n/routes';
import BaseLayout from '../layouts/BaseLayout.astro';

// Traseu curat, în ordinea recomandată. Fiecare pas trimite la ghiduri/playbook-uri reale.
const path = [
  {
    label: 'Email & mesaje',
    desc: 'Aici încep aproape toate țepele. Învață să vezi cine îți scrie și unde duce un link.',
    links: [
      { href: '/ghiduri/cine-iti-scrie', title: 'Cine îți scrie, de fapt?' },
      {
        href: '/ghiduri/verifica-link-fara-sa-l-deschizi',
        title: 'Cum verifici un link fără să-l deschizi',
      },
    ],
  },
  {
    label: 'Conturi & parole',
    desc: 'Cel mai important pas de protecție: al doilea pas la conectare.',
    links: [
      {
        href: '/ghiduri/2fa-authenticator-passkey',
        title: 'Cum îți protejezi conturile',
      },
    ],
  },
  {
    label: 'Recunoaște țepele',
    desc: 'Câteva situații frecvente — ca să le știi înainte să te lovească.',
    links: [
      { href: '/playbook/link-sms-fals', title: 'Link sau SMS fals' },
      { href: '/playbook/cont-spart', title: 'Cont spart sau blocat' },
      { href: '/playbook/real-sau-ai', title: 'Real sau făcut cu AI?' },
      {
        href: '/playbook/oferta-investitii-crypto',
        title: 'Investiții sau crypto frauduloase',
      },
    ],
  },
  {
    label: 'La birou (dacă ești angajat)',
    desc: 'Reguli simple pentru munca de zi cu zi.',
    links: [
      {
        href: '/ghiduri/email-de-la-sef-bec',
        title: 'Email de la „șef” care cere o plată urgentă',
      },
      { href: '/ghiduri/raporteaza-la-it', title: 'Raportează ce e suspect la IT' },
      {
        href: '/ghiduri/datele-companiei-si-clientilor',
        title: 'Datele companiei și ale clienților',
      },
    ],
  },
];
---

<BaseLayout
  title="Începe aici"
  description="Un traseu simplu, în ordine, ca să înveți bazele siguranței digitale — bun și pentru cineva nou într-o echipă. Fără jargon, fără certificate."
  alternates={pageAlternates('start')}
>
  <section class="section">
    <div class="container">
      <div class="head">
        <span class="eyebrow">Traseu recomandat</span>
        <h1>Începe aici</h1>
        <p class="lead">
          Dacă ești nou pe subiect — sau tocmai te-ai alăturat unei echipe —
          parcurge pașii de mai jos, în ordine. În vreo 20 de minute ai bazele
          care te feresc de cele mai multe capcane. Fără jargon, fără teste.
        </p>
      </div>

      <ol class="path">
        {
          path.map((step, i) => (
            <li class="step">
              <div class="step-num" aria-hidden="true">{i + 1}</div>
              <div class="step-body">
                <h2>{step.label}</h2>
                <p class="step-desc">{step.desc}</p>
                <ul class="step-links">
                  {step.links.map((l) => (
                    <li>
                      <a href={l.href}>{l.title} →</a>
                    </li>
                  ))}
                </ul>
              </div>
            </li>
          ))
        }
      </ol>

      <aside class="org">
        <h2>Pentru organizații</h2>
        <p>
          Tot ce e aici e liber de folosit (licență
          <a href="/surse">CC BY</a>) ca material de conștientizare și onboarding
          în orice organizație — poți trimite un coleg nou direct la traseul de
          mai sus.
        </p>
        <p>
          Poate susține și cerințe de tip <strong>ISO 27001 (A.6.3 —
          conștientizare, educație și instruire)</strong>. Un lucru rămâne clar,
          din principiu: <strong>nu emitem certificate și nu ținem evidențe</strong>.
          Dacă o organizație are nevoie de dovada parcurgerii, o gestionează
          singură, cu instrumentele ei. Noi oferim doar cunoașterea.
        </p>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .head {
    max-width: 54ch;
    margin-bottom: var(--space-6);
  }
  .head h1 {
    margin-top: var(--space-2);
  }
  .head .lead {
    margin-top: var(--space-3);
  }
  .path {
    list-style: none;
    padding: 0;
    max-width: var(--container-prose);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .step {
    display: flex;
    gap: var(--space-3);
    padding: var(--space-4);
    background: var(--color-surface-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
  }
  .step-num {
    flex: none;
    display: grid;
    place-items: center;
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 50%;
    background: var(--color-accent);
    color: var(--color-on-accent);
    font-weight: var(--weight-bold);
  }
  .step-body h2 {
    font-size: var(--text-lg);
  }
  .step-desc {
    margin-top: 0.25rem;
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }
  .step-links {
    list-style: none;
    padding: 0;
    margin-top: var(--space-3);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .step-links a {
    font-weight: var(--weight-medium);
    text-decoration: none;
  }
  .step-links a:hover {
    text-decoration: underline;
  }
  .org {
    max-width: var(--container-prose);
    margin-top: var(--space-6);
    padding: var(--space-4);
    border-left: 4px solid var(--color-accent);
    background: var(--color-accent-soft);
    border-radius: var(--radius);
  }
  .org h2 {
    font-size: var(--text-lg);
  }
  .org p {
    margin-top: var(--space-2);
    font-size: var(--text-sm);
  }
</style>
