---
import { pageAlternates } from '../../i18n/routes';
import BaseLayout from '../../layouts/BaseLayout.astro';

// Čistá cesta v odporúčanom poradí — slovenské zrkadlo stránky /incepe-aici.
const path = [
  {
    label: 'E-mail a správy',
    desc: 'Takmer každý podvod začína tu. Nauč sa overiť, kto ti naozaj píše a kam vedie odkaz.',
    links: [
      { href: '/sk/navody/cine-iti-scrie', title: 'Kto ti naozaj píše?' },
      {
        href: '/sk/navody/verifica-link-fara-sa-l-deschizi',
        title: 'Ako overiť odkaz bez toho, aby si ho otvoril',
      },
    ],
  },
  {
    label: 'Účty a heslá',
    desc: 'Najdôležitejší krok ochrany: druhý krok pri prihlásení.',
    links: [
      {
        href: '/sk/navody/2fa-authenticator-passkey',
        title: 'Ako chrániť svoje účty',
      },
    ],
  },
  {
    label: 'Spoznaj podvody',
    desc: 'Niekoľko častých situácií — spoznaj ich skôr, než ťa zaskočia.',
    links: [
      { href: '/sk/playbook/link-sms-fals', title: 'Falošný odkaz alebo SMS' },
      { href: '/sk/playbook/cont-spart', title: 'Hacknutý alebo zablokovaný účet' },
      { href: '/sk/playbook/real-sau-ai', title: 'Skutočné, alebo vytvorené AI?' },
      {
        href: '/sk/playbook/oferta-investitii-crypto',
        title: 'Podvodné investičné a krypto ponuky',
      },
    ],
  },
  {
    label: 'V práci (ak pracuješ)',
    desc: 'Jednoduché pravidlá na každý deň v práci.',
    links: [
      {
        href: '/sk/navody/email-de-la-sef-bec',
        title: 'E-mail od „šéfa“ so žiadosťou o urgentnú platbu',
      },
      { href: '/sk/navody/raporteaza-la-it', title: 'Nahlás IT všetko podozrivé' },
      {
        href: '/sk/navody/datele-companiei-si-clientilor',
        title: 'Firemné a klientske dáta',
      },
    ],
  },
];
---

<BaseLayout
  title="Začni tu"
  description="Jednoduchá cesta krok za krokom k základom digitálnej bezpečnosti — hodí sa aj každému novému človeku v tíme. Bez žargónu, bez certifikátov."
  alternates={pageAlternates('start')}
>
  <section class="section">
    <div class="container">
      <div class="head">
        <span class="eyebrow">Odporúčaná cesta</span>
        <h1>Začni tu</h1>
        <p class="lead">
          Ak je pre teba téma nová — alebo práve nastupuješ do tímu — prejdi
          kroky nižšie po poradí. Za približne 20 minút získaš základy, ktoré
          chránia pred väčšinou pascí. Bez žargónu, bez testov.
        </p>
      </div>

      <ol class="path">
        {
          path.map((step, i) => (
            <li class="step">
              <div class="step-num" aria-hidden="true">{i + 1}</div>
              <div class="step-body">
                <h2>{step.label}</h2>
                <p class="step-desc">{step.desc}</p>
                <ul class="step-links">
                  {step.links.map((l) => (
                    <li>
                      <a href={l.href}>{l.title} →</a>
                    </li>
                  ))}
                </ul>
              </div>
            </li>
          ))
        }
      </ol>

      <aside class="org">
        <h2>Pre organizácie</h2>
        <p>
          Všetko tu možno zadarmo využívať (licencia
          <a href="/sk/zdroje">CC BY</a>) ako osvetový a zaškoľovací materiál
          v akejkoľvek organizácii — nového človeka v tíme môžeš rovno poslať
          na cestu vyššie.
        </p>
        <p>
          Môže tiež podporiť požiadavky ako <strong>ISO 27001 (A.6.3 —
          povedomie, vzdelávanie a školenie)</strong>. Jedno zostáva jasné, z
          princípu: <strong>nevydávame certifikáty a nevedieme
          evidenciu</strong>. Ak organizácia potrebuje potvrdenie o
          absolvovaní, rieši si ho sama, vlastnými nástrojmi. My dodávame len
          znalosti.
        </p>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .head {
    max-width: 54ch;
    margin-bottom: var(--space-6);
  }
  .head h1 {
    margin-top: var(--space-2);
  }
  .head .lead {
    margin-top: var(--space-3);
  }
  .path {
    list-style: none;
    padding: 0;
    max-width: var(--container-prose);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .step {
    display: flex;
    gap: var(--space-3);
    padding: var(--space-4);
    background: var(--color-surface-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
  }
  .step-num {
    flex: none;
    display: grid;
    place-items: center;
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 50%;
    background: var(--color-accent);
    color: var(--color-on-accent);
    font-weight: var(--weight-bold);
  }
  .step-body h2 {
    font-size: var(--text-lg);
  }
  .step-desc {
    margin-top: 0.25rem;
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }
  .step-links {
    list-style: none;
    padding: 0;
    margin-top: var(--space-3);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .step-links a {
    font-weight: var(--weight-medium);
    text-decoration: none;
  }
  .step-links a:hover {
    text-decoration: underline;
  }
  .org {
    max-width: var(--container-prose);
    margin-top: var(--space-6);
    padding: var(--space-4);
    border-left: 4px solid var(--color-accent);
    background: var(--color-accent-soft);
    border-radius: var(--radius);
  }
  .org h2 {
    font-size: var(--text-lg);
  }
  .org p {
    margin-top: var(--space-2);
    font-size: var(--text-sm);
  }
</style>
