---
import { pageAlternates } from '../../i18n/routes';
import BaseLayout from '../../layouts/BaseLayout.astro';

// Čistá cesta v doporučeném pořadí — české zrcadlo stránky /incepe-aici.
const path = [
  {
    label: 'E-mail a zprávy',
    desc: 'Skoro každý podvod začíná tady. Nauč se ověřit, kdo ti opravdu píše a kam vede odkaz.',
    links: [
      { href: '/cs/navody/cine-iti-scrie', title: 'Kdo ti opravdu píše?' },
      {
        href: '/cs/navody/verifica-link-fara-sa-l-deschizi',
        title: 'Jak ověřit odkaz, aniž ho otevřeš',
      },
    ],
  },
  {
    label: 'Účty a hesla',
    desc: 'Nejdůležitější krok ochrany: druhý krok při přihlášení.',
    links: [
      {
        href: '/cs/navody/2fa-authenticator-passkey',
        title: 'Jak chránit své účty',
      },
    ],
  },
  {
    label: 'Poznej podvody',
    desc: 'Několik častých situací — poznej je dřív, než tě zaskočí.',
    links: [
      { href: '/cs/playbook/link-sms-fals', title: 'Falešný odkaz nebo SMS' },
      { href: '/cs/playbook/cont-spart', title: 'Hacknutý nebo zablokovaný účet' },
      { href: '/cs/playbook/real-sau-ai', title: 'Skutečné, nebo vytvořené AI?' },
      {
        href: '/cs/playbook/oferta-investitii-crypto',
        title: 'Podvodné investiční a krypto nabídky',
      },
    ],
  },
  {
    label: 'V práci (pokud pracuješ)',
    desc: 'Jednoduchá pravidla pro každý den v práci.',
    links: [
      {
        href: '/cs/navody/email-de-la-sef-bec',
        title: 'E-mail od „šéfa“ s žádostí o urgentní platbu',
      },
      { href: '/cs/navody/raporteaza-la-it', title: 'Nahlas IT všechno podezřelé' },
      {
        href: '/cs/navody/datele-companiei-si-clientilor',
        title: 'Firemní a klientská data',
      },
    ],
  },
];
---

<BaseLayout
  title="Začni tady"
  description="Jednoduchá cesta krok za krokem k základům digitální bezpečnosti — hodí se i každému novému člověku v týmu. Bez žargonu, bez certifikátů."
  alternates={pageAlternates('start')}
>
  <section class="section">
    <div class="container">
      <div class="head">
        <span class="eyebrow">Doporučená cesta</span>
        <h1>Začni tady</h1>
        <p class="lead">
          Pokud je pro tebe téma nové — nebo právě nastupuješ do týmu — projdi
          kroky níže popořadě. Za zhruba 20 minut získáš základy, které chrání
          před většinou pastí. Bez žargonu, bez testů.
        </p>
      </div>

      <ol class="path">
        {
          path.map((step, i) => (
            <li class="step">
              <div class="step-num" aria-hidden="true">{i + 1}</div>
              <div class="step-body">
                <h2>{step.label}</h2>
                <p class="step-desc">{step.desc}</p>
                <ul class="step-links">
                  {step.links.map((l) => (
                    <li>
                      <a href={l.href}>{l.title} →</a>
                    </li>
                  ))}
                </ul>
              </div>
            </li>
          ))
        }
      </ol>

      <aside class="org">
        <h2>Pro organizace</h2>
        <p>
          Všechno tady lze zdarma využívat (licence
          <a href="/cs/zdroje">CC BY</a>) jako osvětový a zaškolovací materiál
          v jakékoli organizaci — nového člověka v týmu můžeš rovnou poslat na
          cestu výše.
        </p>
        <p>
          Může také podpořit požadavky jako <strong>ISO 27001 (A.6.3 —
          povědomí, vzdělávání a školení)</strong>. Jedno zůstává jasné, z
          principu: <strong>nevydáváme certifikáty a nevedeme
          evidenci</strong>. Pokud organizace potřebuje potvrzení o
          absolvování, řeší si ho sama, vlastními nástroji. My dodáváme jen
          znalosti.
        </p>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .head {
    max-width: 54ch;
    margin-bottom: var(--space-6);
  }
  .head h1 {
    margin-top: var(--space-2);
  }
  .head .lead {
    margin-top: var(--space-3);
  }
  .path {
    list-style: none;
    padding: 0;
    max-width: var(--container-prose);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .step {
    display: flex;
    gap: var(--space-3);
    padding: var(--space-4);
    background: var(--color-surface-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
  }
  .step-num {
    flex: none;
    display: grid;
    place-items: center;
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 50%;
    background: var(--color-accent);
    color: var(--color-on-accent);
    font-weight: var(--weight-bold);
  }
  .step-body h2 {
    font-size: var(--text-lg);
  }
  .step-desc {
    margin-top: 0.25rem;
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }
  .step-links {
    list-style: none;
    padding: 0;
    margin-top: var(--space-3);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .step-links a {
    font-weight: var(--weight-medium);
    text-decoration: none;
  }
  .step-links a:hover {
    text-decoration: underline;
  }
  .org {
    max-width: var(--container-prose);
    margin-top: var(--space-6);
    padding: var(--space-4);
    border-left: 4px solid var(--color-accent);
    background: var(--color-accent-soft);
    border-radius: var(--radius);
  }
  .org h2 {
    font-size: var(--text-lg);
  }
  .org p {
    margin-top: var(--space-2);
    font-size: var(--text-sm);
  }
</style>
