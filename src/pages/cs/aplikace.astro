---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { pageAlternates } from '../../i18n/routes';
---

<BaseLayout
  title="Nainstaluj si aplikaci"
  description="Digital Compass si můžeš nainstalovat jako aplikaci na telefon i počítač, zdarma, přímo z prohlížeče — a návody si můžeš uložit, abys je měl i bez internetu."
  alternates={pageAlternates('pwa')}
>
  <section class="section">
    <div class="container prose">
      <span class="eyebrow">Aplikace</span>
      <h1>Měj návod po ruce — i bez internetu</h1>

      <div class="content">
        <p class="lead">
          Digital Compass si můžeš nainstalovat jako aplikaci na telefon nebo
          počítač. Neprocházíš žádným obchodem s aplikacemi, nezakládáme ti
          účet, nic to nestojí: prohlížeč, který už máš, to umí sám.
        </p>
        <p>
          Proč na tom záleží? Protože chvíle, kdy návod potřebuješ, je přesně
          ta chvíle, kdy se něco pokazilo — někdy i internet. Jednou
          nainstalovaná aplikace se otevře jedním klepnutím a uložené návody
          zůstanou čitelné <strong>i bez připojení</strong>.
        </p>
      </div>

      <div class="offline-box">
        <h2>Ulož si návody pro offline</h2>
        <p>
          Stiskni tlačítko a všechny situace a návody v tomto jazyce se uloží
          do tvého telefonu nebo počítače. Příště se otevřou i bez internetu.
        </p>
        <button id="save-offline" class="btn-primary" type="button">
          Uložit návody offline
        </button>
        <p id="save-status" class="save-status" role="status" aria-live="polite"></p>
      </div>

      <div class="content">
        <h2>Jak aplikaci nainstalovat</h2>

        <h3>Na iPhonu nebo iPadu (Safari)</h3>
        <ol>
          <li>Otevři compass.madeinro.eu v <strong>Safari</strong>.</li>
          <li>Klepni na tlačítko <strong>Sdílet</strong> (čtverec se šipkou nahoru, dole uprostřed).</li>
          <li>Sjeď dolů a vyber <strong>„Přidat na plochu"</strong>, pak <strong>Přidat</strong>.</li>
        </ol>

        <h3>Na Androidu (Chrome)</h3>
        <ol>
          <li>Otevři stránku v <strong>Chromu</strong>.</li>
          <li>Klepni na menu <strong>⋮</strong> (vpravo nahoře).</li>
          <li>Vyber <strong>„Přidat na plochu"</strong> nebo <strong>„Nainstalovat aplikaci"</strong>.</li>
        </ol>

        <h3>Na Windows, macOS nebo Linuxu (Chrome nebo Edge)</h3>
        <ol>
          <li>Otevři stránku v <strong>Chromu</strong> nebo <strong>Edgi</strong>.</li>
          <li>Najdi vpravo v adresním řádku <strong>ikonu instalace</strong> (monitor se šipkou).</li>
          <li>Klikni na ni a potvrď tlačítkem <strong>Nainstalovat</strong>. Aplikace se objeví jako jakýkoli jiný program.</li>
        </ol>

        <h3>Firefox</h3>
        <p>
          Na Androidu má Firefox v menu také „Přidat na plochu". Na počítači
          Firefox takové aplikace neinstaluje — ale ukládání offline popsané
          výš funguje i tam.
        </p>

        <h2>Dobré vědět</h2>
        <ul>
          <li>Aplikace je tentýž web — <strong>aktualizuje se sama</strong>, když máš internet.</li>
          <li>Nechce žádná zvláštní oprávnění a nesbírá nic navíc.</li>
          <li>Kdykoli ji můžeš smazat, jako jakoukoli jinou aplikaci.</li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline data-lang="cs">
  (function () {
    var LANG = document.currentScript.getAttribute('data-lang');
    var MSG = {
      saving: 'Ukládá se…',
      done: 'Hotovo! Návody jsou uložené a fungují i bez internetu.',
      progress: function (d, t) { return 'Ukládá se… ' + d + ' z ' + t; },
      unsupported: 'Tento prohlížeč neumí ukládat offline — zkus Chrome, Edge nebo Safari.',
      error: 'Teď se uložit nepodařilo. Zkontroluj internet a zkus to znovu.',
    };
    var btn = document.getElementById('save-offline');
    var status = document.getElementById('save-status');
    if (!btn) return;
    if (!('serviceWorker' in navigator) || !('caches' in window)) {
      btn.disabled = true;
      status.textContent = MSG.unsupported;
      return;
    }
    navigator.serviceWorker.addEventListener('message', function (e) {
      if (e.data && e.data.type === 'CACHE_PROGRESS') {
        status.textContent =
          e.data.done >= e.data.total ? MSG.done : MSG.progress(e.data.done, e.data.total);
      }
    });
    btn.addEventListener('click', function () {
      status.textContent = MSG.saving;
      btn.disabled = true;
      fetch('/data/agents.json')
        .then(function (r) { return r.json(); })
        .then(function (data) {
          var urls = [];
          ['situatii', 'ghiduri'].forEach(function (k) {
            (data[k] || []).forEach(function (item) {
              if (item.lang === LANG) urls.push(new URL(item.url).pathname);
            });
          });
          urls.push(location.pathname);
          return navigator.serviceWorker.ready.then(function (reg) {
            reg.active.postMessage({ type: 'CACHE_URLS', urls: urls });
          });
        })
        .catch(function () {
          status.textContent = MSG.error;
          btn.disabled = false;
        });
    });
  })();
</script>

<style>
  .prose h1 {
    margin-top: var(--space-2);
    max-width: 24ch;
  }
  .content {
    margin-top: var(--space-4);
  }
  .content h2 {
    margin-top: var(--space-5);
  }
  .content h3 {
    margin-top: var(--space-4);
    font-size: var(--text-lg);
  }
  .content ol,
  .content ul {
    margin-top: var(--space-2);
    padding-left: 1.4em;
  }
  .content li + li {
    margin-top: 0.35rem;
  }
  .offline-box {
    margin-top: var(--space-5);
    padding: var(--space-4);
    border-left: 4px solid var(--color-accent);
    background: var(--color-accent-soft);
    border-radius: var(--radius);
  }
  .offline-box h2 {
    font-size: var(--text-xl);
  }
  .offline-box p {
    margin-top: var(--space-2);
    max-width: var(--container-prose);
  }
  .btn-primary {
    display: inline-block;
    margin-top: var(--space-3);
    padding: 0.85rem 1.5rem;
    background: var(--color-accent);
    color: var(--color-on-accent);
    border: none;
    border-radius: var(--radius);
    font-weight: var(--weight-bold);
    font-size: var(--text-base);
    cursor: pointer;
    box-shadow: var(--shadow-soft);
  }
  .btn-primary:hover {
    background: var(--color-accent-strong);
  }
  .btn-primary:disabled {
    opacity: 0.6;
    cursor: default;
  }
  .save-status {
    margin-top: var(--space-2);
    font-weight: var(--weight-medium);
    min-height: 1.4em;
  }
</style>
