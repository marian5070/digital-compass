---
import { pageAlternates } from '../../i18n/routes';
import BaseLayout from '../../layouts/BaseLayout.astro';

// Klarer Pfad, in der empfohlenen Reihenfolge — deutsches Spiegelbild der Seite /incepe-aici.
const path = [
  {
    label: 'E-Mail und Nachrichten',
    desc: 'Fast jeder Betrug beginnt hier. Lernen Sie zu prüfen, wer Ihnen wirklich schreibt und wohin ein Link führt.',
    links: [
      { href: '/de/ratgeber/cine-iti-scrie', title: 'Wer schreibt Ihnen wirklich?' },
      {
        href: '/de/ratgeber/verifica-link-fara-sa-l-deschizi',
        title: 'Einen Link prüfen, ohne ihn zu öffnen',
      },
    ],
  },
  {
    label: 'Konten und Passwörter',
    desc: 'Der wichtigste Schutzschritt: der zweite Schritt beim Anmelden.',
    links: [
      {
        href: '/de/ratgeber/2fa-authenticator-passkey',
        title: 'So schützen Sie Ihre Konten',
      },
    ],
  },
  {
    label: 'Betrug erkennen',
    desc: 'Einige häufige Situationen — lernen Sie sie kennen, bevor sie Sie überraschen.',
    links: [
      { href: '/de/playbook/link-sms-fals', title: 'Gefälschter Link oder SMS' },
      { href: '/de/playbook/cont-spart', title: 'Gehacktes oder gesperrtes Konto' },
      { href: '/de/playbook/real-sau-ai', title: 'Echt oder von KI gemacht?' },
      {
        href: '/de/playbook/oferta-investitii-crypto',
        title: 'Betrügerische Investment- und Krypto-Angebote',
      },
    ],
  },
  {
    label: 'Bei der Arbeit (falls Sie arbeiten)',
    desc: 'Einfache Regeln für den Arbeitsalltag.',
    links: [
      {
        href: '/de/ratgeber/email-de-la-sef-bec',
        title: 'E-Mail vom „Chef“ mit dringender Zahlungsaufforderung',
      },
      { href: '/de/ratgeber/raporteaza-la-it', title: 'Melden Sie der IT alles Verdächtige' },
      {
        href: '/de/ratgeber/datele-companiei-si-clientilor',
        title: 'Daten des Unternehmens und der Kunden',
      },
    ],
  },
];
---

<BaseLayout
  title="Hier starten"
  description="Ein einfacher Pfad, Schritt für Schritt, zu den Grundlagen der digitalen Sicherheit — auch für jede neue Person im Team. Ohne Fachjargon, ohne Zertifikate."
  alternates={pageAlternates('start')}
>
  <section class="section">
    <div class="container">
      <div class="head">
        <span class="eyebrow">Empfohlener Pfad</span>
        <h1>Hier starten</h1>
        <p class="lead">
          Wenn das Thema neu für Sie ist — oder Sie gerade neu in ein Team
          kommen — gehen Sie die folgenden Schritte der Reihe nach durch. In
          etwa 20 Minuten haben Sie die Grundlagen, die vor den meisten Fallen
          schützen. Ohne Fachjargon, ohne Tests.
        </p>
      </div>

      <ol class="path">
        {
          path.map((step, i) => (
            <li class="step">
              <div class="step-num" aria-hidden="true">{i + 1}</div>
              <div class="step-body">
                <h2>{step.label}</h2>
                <p class="step-desc">{step.desc}</p>
                <ul class="step-links">
                  {step.links.map((l) => (
                    <li>
                      <a href={l.href}>{l.title} →</a>
                    </li>
                  ))}
                </ul>
              </div>
            </li>
          ))
        }
      </ol>

      <aside class="org">
        <h2>Für Organisationen</h2>
        <p>
          Alles hier kann kostenlos genutzt werden (Lizenz
          <a href="/de/quellen">CC BY</a>) — als Sensibilisierungs- und
          Einarbeitungsmaterial in jeder Organisation. Eine neue Person im Team
          können Sie direkt auf den obigen Pfad verweisen.
        </p>
        <p>
          Er kann auch Anforderungen wie <strong>ISO 27001 (A.6.3 —
          Informationssicherheitsbewusstsein, -ausbildung und
          -schulung)</strong> unterstützen. Eines bleibt dabei klar, aus
          Prinzip: <strong>Wir stellen keine Zertifikate aus und führen keine
          Aufzeichnungen</strong>. Wenn eine Organisation einen Nachweis über
          die Teilnahme braucht, verwaltet sie das selbst, mit eigenen
          Werkzeugen. Wir liefern nur das Wissen.
        </p>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .head {
    max-width: 54ch;
    margin-bottom: var(--space-6);
  }
  .head h1 {
    margin-top: var(--space-2);
  }
  .head .lead {
    margin-top: var(--space-3);
  }
  .path {
    list-style: none;
    padding: 0;
    max-width: var(--container-prose);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .step {
    display: flex;
    gap: var(--space-3);
    padding: var(--space-4);
    background: var(--color-surface-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
  }
  .step-num {
    flex: none;
    display: grid;
    place-items: center;
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 50%;
    background: var(--color-accent);
    color: var(--color-on-accent);
    font-weight: var(--weight-bold);
  }
  .step-body h2 {
    font-size: var(--text-lg);
  }
  .step-desc {
    margin-top: 0.25rem;
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }
  .step-links {
    list-style: none;
    padding: 0;
    margin-top: var(--space-3);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .step-links a {
    font-weight: var(--weight-medium);
    text-decoration: none;
  }
  .step-links a:hover {
    text-decoration: underline;
  }
  .org {
    max-width: var(--container-prose);
    margin-top: var(--space-6);
    padding: var(--space-4);
    border-left: 4px solid var(--color-accent);
    background: var(--color-accent-soft);
    border-radius: var(--radius);
  }
  .org h2 {
    font-size: var(--text-lg);
  }
  .org p {
    margin-top: var(--space-2);
    font-size: var(--text-sm);
  }
</style>
