---
import BaseLayout from '../../layouts/BaseLayout.astro';

const offer = [
  'Világosság és magyarázatok egyszerű, emberi nyelven, szakzsargon nélkül',
  'Konkrét lépések valós helyzetekre, abban a sorrendben, ahogy számít',
  'Hivatkozott források, amelyeket magad is ellenőrizhetsz',
  'Valódi telefonszámok és linkek, ahol Romániában bejelenthetsz egy problémát',
  'Szabad hozzáférés — fiók, fizetés és nyomkövetés nélkül',
];

const dontOffer = [
  'Diplomák, tanúsítványok vagy igazolások',
  'Tekintélyjelvények vagy szakmai státusz',
  'Karrier- vagy állásígéretek',
  'Intézményi elismerés',
  'Megfelelőségi színház',
];
---

<BaseLayout
  title="Miért létezünk"
  description="Nem tanúsító akadémia vagyunk. Nyilvános eszköz vagyunk a digitális világ megértéséhez és az alkalmazkodáshoz. Íme, mit kínálunk — és mit nem."
  alternates={{ ro: '/de-ce-existam', en: '/en/why-we-exist', hu: '/hu/miert-letezunk' }}
>
  <article class="section">
    <div class="container prose">
      <span class="eyebrow">Miért létezünk</span>
      <h1>Nem diplomát adunk. Világosságot adunk.</h1>

      <div class="content">
        <p class="lead">
          Ezt a platformot annak az embernek építjük, akinek egy olyan
          digitális világhoz kell alkalmazkodnia, amely gyorsabban változik,
          mint ahogy az intézmények elmagyarázni tudnák.
        </p>

        <p>
          Sok szó esik a digitalizációról, a kiberbiztonságról, a „digitális
          készségekről” és az ellenálló képességről. Közpénz megy el
          beszédekre és stratégiákra. De túl gyakran, amikor egy hétköznapi
          embernek tényleg baja van — feltört fiók, átverés, csaló
          telefonhívás —, nem talál világos, nyilvános és gyakorlati utat.
          Zárt oldalakat talál, szakzsargont vagy hallgatást.
        </p>

        <p>
          Nem azt mondjuk, hogy mindennek nyilvánosnak kell lennie. A
          biztonságban van olyan tartalom, amelynek ellenőrzés alatt kell
          maradnia. De ha nyilvánosan beszélünk „digitáliskészség-hiányról”,
          akkor a hétköznapi ember megérdemel legalább egy egyszerű,
          hozzáférhető eszközt. Ezt a hiányt töltjük be. Nem helyettesítjük
          az intézményeket — pótoljuk, ami hiányzik.
        </p>
      </div>

      <div class="offer-grid">
        <section class="offer offer-yes" aria-labelledby="oferim">
          <h2 id="oferim">Mit kínálunk</h2>
          <ul>
            {offer.map((item) => <li>{item}</li>)}
          </ul>
        </section>

        <section class="offer offer-no" aria-labelledby="nu-oferim">
          <h2 id="nu-oferim">Mit NEM kínálunk</h2>
          <ul>
            {dontOffer.map((item) => <li>{item}</li>)}
          </ul>
        </section>
      </div>

      <div class="content closing">
        <p>
          A cél nem az, hogy diplomát adjunk a kezedbe. A cél az, hogy
          kevésbé légy sebezhető, tájékozottabb és talpraesettebb abban a
          világban, amelyben élsz. Az érték nem a végén van, egy
          tanúsítványban — hanem minden oldalban, minden lépésben, abban a
          pillanatban, amikor azt mondod:
          <strong>„Most már tudom, mit kell tennem.”</strong>
        </p>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .prose h1 {
    margin-top: var(--space-2);
    max-width: 18ch;
  }
  .content {
    margin-top: var(--space-4);
  }
  .offer-grid {
    display: grid;
    gap: var(--space-4);
    grid-template-columns: 1fr;
    margin-block: var(--space-6);
  }
  @media (min-width: 44rem) {
    .offer-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  .offer {
    padding: var(--space-4);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
  }
  .offer h2 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-3);
  }
  .offer ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .offer li {
    padding-left: 1.8rem;
    position: relative;
  }
  .offer-yes {
    background: var(--color-safe-soft);
    border-color: color-mix(in oklch, var(--color-safe) 35%, transparent);
  }
  .offer-yes h2 {
    color: var(--color-safe-text);
  }
  .offer-yes li::before {
    content: '✓';
    position: absolute;
    left: 0;
    font-weight: var(--weight-bold);
    color: var(--color-safe);
  }
  .offer-no {
    background: var(--color-surface-2);
  }
  .offer-no li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--color-text-muted);
  }
  .closing {
    padding: var(--space-4);
    border-left: 4px solid var(--color-accent);
    background: var(--color-accent-soft);
    border-radius: var(--radius);
  }
</style>
