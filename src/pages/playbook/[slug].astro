---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import StepList from '../../components/StepList.astro';
import DontList from '../../components/DontList.astro';
import ReportBox from '../../components/ReportBox.astro';
import SourceList from '../../components/SourceList.astro';

export async function getStaticPaths() {
  const playbooks = await getCollection('playbooks');
  return playbooks.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { data } = entry;
const { Content } = await render(entry);

// Structured data HowTo — ajută Google să afișeze pașii ca rezultat bogat,
// exact felul în care publicul nostru caută („ce fac dacă...").
const stripTags = (s: string) => s.replace(/<[^>]+>/g, '');
const howTo = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: data.title,
  description: data.summary,
  step: data.steps.map((step, i) => ({
    '@type': 'HowToStep',
    position: i + 1,
    text: stripTags(step),
  })),
};
---

<BaseLayout title={data.title} description={data.summary}>
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(howTo)}
    is:inline
  />
  <article class="playbook">
    <div class="container">
      <a href="/" class="back">← Toate situațiile</a>

      <header class="pb-header">
        {
          data.severity === 'urgent' && (
            <span class="tag tag-urgent">Urgent — acționează acum</span>
          )
        }
        <h1>{data.title}</h1>
      </header>

      <div class="pb-grid">
        <div class="pb-main">
          <!-- Întâi, respiră (din corpul markdown) -->
          <section class="breathe" aria-label="Întâi, respiră">
            <div class="content">
              <Content />
            </div>
          </section>

          <!-- Primii pași -->
          <section class="block block-steps" aria-labelledby="pasi">
            <h2 id="pasi">Primii pași, acum</h2>
            <StepList steps={data.steps} />
          </section>

          <!-- Ce să NU faci -->
          {
            data.donts.length > 0 && (
              <section class="block block-donts" aria-labelledby="nu">
                <h2 id="nu">Ce să NU faci</h2>
                <DontList items={data.donts} />
              </section>
            )
          }

          <!-- Cum recunoști data viitoare -->
          {
            data.recognize.length > 0 && (
              <section class="block" aria-labelledby="recunosti">
                <h2 id="recunosti">Cum îți dai seama data viitoare</h2>
                <ul class="recognize">
                  {data.recognize.map((r) => (
                    <li set:html={r} />
                  ))}
                </ul>
              </section>
            )
          }
        </div>

        <aside class="pb-aside">
          {
            data.report.length > 0 && (
              <section class="block block-report" aria-labelledby="raportezi">
                <h2 id="raportezi">Unde raportezi</h2>
                <ReportBox channels={data.report} />
              </section>
            )
          }

          <section class="block block-sources" aria-labelledby="surse">
            <h2 id="surse" class="h-small">Surse</h2>
            <SourceList sources={data.sources} lastReviewed={data.lastReviewed} />
          </section>
        </aside>
      </div>

      <p class="disclaimer">
        Acest ghid e orientativ și te ajută să acționezi rapid. Nu înlocuiește
        instrucțiunile oficiale ale băncii tale, ale poliției sau ale
        autorităților. La dubii, sună la numerele de mai sus.
      </p>
    </div>
  </article>
</BaseLayout>

<style>
  .playbook {
    padding-top: var(--space-5);
  }
  .back {
    display: inline-block;
    margin-bottom: var(--space-4);
    font-weight: var(--weight-medium);
    text-decoration: none;
    color: var(--color-text-muted);
  }
  .back:hover {
    color: var(--color-accent-strong);
  }
  .pb-header {
    margin-bottom: var(--space-5);
  }
  .pb-header h1 {
    font-size: var(--text-2xl);
    max-width: 24ch;
  }
  .tag {
    display: inline-block;
    margin-bottom: var(--space-3);
    padding: 0.3rem 0.8rem;
    border-radius: 999px;
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
  }
  .tag-urgent {
    background: var(--color-danger-soft);
    color: var(--color-danger-text);
  }
  .pb-grid {
    display: grid;
    gap: var(--space-5);
    grid-template-columns: 1fr;
  }
  @media (min-width: 60rem) {
    .pb-grid {
      grid-template-columns: minmax(0, 1.7fr) minmax(0, 1fr);
      align-items: start;
    }
    .pb-aside {
      position: sticky;
      top: 5rem;
    }
  }
  .breathe {
    padding: var(--space-4);
    background: var(--color-accent-soft);
    border-radius: var(--radius);
    border-left: 4px solid var(--color-accent);
    margin-bottom: var(--space-5);
  }
  .breathe :global(p:first-child) {
    font-weight: var(--weight-bold);
    font-size: var(--text-lg);
  }
  .block {
    margin-bottom: var(--space-5);
  }
  .block h2 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-3);
  }
  .block h2.h-small {
    font-size: var(--text-lg);
  }
  .block-donts h2 {
    color: var(--color-danger-text);
  }
  .recognize {
    padding-left: 1.2em;
  }
  .recognize li + li {
    margin-top: var(--space-2);
  }
  .recognize :global(strong) {
    font-weight: var(--weight-bold);
  }
  .block-sources {
    padding: var(--space-4);
    background: var(--color-surface-2);
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
  }
  .disclaimer {
    margin-top: var(--space-4);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
    max-width: var(--container-prose);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }
</style>
