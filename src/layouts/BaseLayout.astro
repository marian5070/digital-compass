---
import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import type { Lang } from '../lib/i18n-content';

interface Props {
  title: string;
  description: string;
  /** Path-urile paginii în ambele limbi — emit hreflang + comutatorul de limbă. */
  alternates?: { ro: string; en: string };
}

const lang = (Astro.currentLocale ?? 'ro') as Lang;
const { title, description, alternates } = Astro.props;
const fullTitle =
  title === 'Digital Compass' ? title : `${title} · Digital Compass`;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const abs = (p: string) => new URL(p, Astro.site).href;
const altUrl = alternates ? alternates[lang === 'ro' ? 'en' : 'ro'] : undefined;
const ogAlt =
  lang === 'en'
    ? 'Digital Compass — a public digital-safety guide for Romania'
    : 'Digital Compass — ghid public de siguranță digitală, în română';
const skipLabel = lang === 'en' ? 'Skip to content' : 'Sari la conținut';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {
      alternates && (
        <>
          <link rel="alternate" hreflang="ro" href={abs(alternates.ro)} />
          <link rel="alternate" hreflang="en" href={abs(alternates.en)} />
          <link rel="alternate" hreflang="x-default" href={abs(alternates.ro)} />
        </>
      )
    }
    <meta name="color-scheme" content="light dark" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Digital Compass" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={lang === 'en' ? 'en_US' : 'ro_RO'} />
    <meta property="og:image" content={new URL('/og-image.png', Astro.site).href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={new URL('/og-image.png', Astro.site).href} />

    <link
      rel="icon"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 48 48'%3E%3Ccircle cx='24' cy='24' r='21' fill='none' stroke='%235b5bd6' stroke-width='3'/%3E%3Cpath d='M24 8 L29 24 L24 21 L19 24 Z' fill='%235b5bd6'/%3E%3C/svg%3E"
    />

    <slot name="head" />
    <!-- WebMCP: unelte pentru agenții AI din browser; no-op fără API. -->
    <script src="/webmcp.js" defer is:inline></script>
  </head>
  <body>
    <a href="#main" class="skip-link">{skipLabel}</a>
    <SiteHeader altUrl={altUrl} />
    <main id="main">
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
